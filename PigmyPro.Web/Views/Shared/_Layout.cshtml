<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PigmyPro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div id="sidebar">
            <div class="sidebar-header">
                <img src="~/Three_Star_Logo-t.png" alt="Three Star Logo" style="height: 32px; width: auto; object-fit: contain;" />
                <span class="logo-text">PigmyPro</span>
            </div>

            <div class="sidebar-nav">
                <div class="nav-section">Application</div>
                <a href="/Dashboard/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-grid-fill"></i> Dashboard
                </a>

                <div class="nav-section">Organization</div>
                @if (User.IsInRole("SuperAdmin"))
                {
                    <a href="/Bank/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Bank" ? "active" : "")">
                        <i class="bi bi-bank"></i> Banks
                    </a>
                }
                <a href="/Branch/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Branch" ? "active" : "")">
                    <i class="bi bi-diagram-3-fill"></i> Branches
                </a>
                <a href="/User/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")">
                    <i class="bi bi-people-fill"></i> System Users
                </a>

                <div class="nav-section">Banking Masters</div>
                <a href="/Agent/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Agent" ? "active" : "")">
                    <i class="bi bi-person-badge-fill"></i> Field Agents
                </a>
                <a href="/Account/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" ? "active" : "")">
                    <i class="bi bi-wallet2"></i> Customer Accounts
                </a>
                @if (User.IsInRole("BankAdmin") || User.IsInRole("BranchAdmin"))
                {
                    <a href="/Map/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Map" ? "active" : "")">
                        <i class="bi bi-geo-alt-fill"></i> Collection Map
                    </a>
                }

                <div class="nav-section">Mobile Sync</div>
                @if (User.IsInRole("BankAdmin") || User.IsInRole("BranchAdmin"))
                {
                    <a href="/MobileImport/Export" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "MobileImport" && ViewContext.RouteData.Values["action"]?.ToString() == "Export" ? "active" : "")">
                        <i class="bi bi-upload"></i> Export Collections
                    </a>
                    <a href="/MobileImport/Upload" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "MobileImport" && ViewContext.RouteData.Values["action"]?.ToString() == "Upload" ? "active" : "")">
                        <i class="bi bi-download"></i> Upload File
                    </a>
                }

                <div class="nav-section">Reports</div>
                @{
                    var reportController = ViewContext.RouteData.Values["controller"]?.ToString();
                    var reportAction = ViewContext.RouteData.Values["action"]?.ToString();
                }
                <a href="/Report/DailyCollection" class="nav-link @(reportController == "Report" && reportAction == "DailyCollection" ? "active" : "")">
                    <i class="bi bi-journal-text"></i> Daily Collection
                </a>
                <a href="/Report/AgentSummary" class="nav-link @(reportController == "Report" && reportAction == "AgentSummary" ? "active" : "")">
                    <i class="bi bi-person-lines-fill"></i> Agent Summary
                </a>
                @{
                    var psController = ViewContext.RouteData.Values["controller"]?.ToString();
                }
                <a href="/PigmyStatement/Index" class="nav-link @(psController == "PigmyStatement" ? "active" : "")">
                    <i class="bi bi-receipt"></i> Pigmy Statement
                </a>
            </div>
        </div>

        <div id="main-content">
            <header class="top-navbar">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        @Html.Raw(ViewData["Breadcrumb"] ?? "<li class='breadcrumb-item active'>Dashboard</li>")
                    </ol>
                </nav>
                <div class="user-info-area">
                    @{
                        var displayName = User.FindFirst("DisplayName")?.Value ?? "User";
                        var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
                        var avatarLetter = !string.IsNullOrEmpty(displayName) ? displayName[0].ToString().ToUpper() : "U";
                        var roleFriendly = userRole switch
                        {
                            "SuperAdmin" => "Super Admin",
                            "BankAdmin" => "Bank Admin",
                            "BranchAdmin" => "Branch Admin",
                            _ => userRole
                        };
                    }
                    <div class="user-info-block">
                        <div class="user-avatar">@avatarLetter</div>
                        <div class="user-info-text">
                            <div class="user-info-name">@displayName</div>
                            <div class="user-info-role">@roleFriendly</div>
                        </div>
                    </div>
                    <div style="width:1px;height:24px;background:var(--color-border);margin:0 8px;"></div>
                    <form asp-controller="Auth" asp-action="Logout" method="post" id="logoutForm" style="margin:0;">
                         @Html.AntiForgeryToken()
                         <button type="submit" class="signout-btn">
                            <i class="bi bi-power"></i> Sign Out
                         </button>
                    </form>
                </div>
            </header>

            <div class="page-body">
                @RenderBody()
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            (function () {
                var TIMEOUT_MS = 28 * 60 * 1000; // 28 minutes (warn 2 min before 30min timeout)
                var WARNING_MS = 2 * 60 * 1000;  // 2 minutes to respond
                var timer, warningTimer;

                function resetTimer() {
                    clearTimeout(timer);
                    clearTimeout(warningTimer);
                    timer = setTimeout(showWarning, TIMEOUT_MS);
                }

                function showWarning() {
                    warningTimer = setTimeout(function () { /* session expires naturally */ }, WARNING_MS);
                    if (confirm('Your session will expire in 2 minutes due to inactivity. Click OK to stay logged in.')) {
                        fetch('/Auth/KeepAlive', { credentials: 'same-origin' }).then(function () { resetTimer(); });
                    }
                }

                document.addEventListener('mousemove', resetTimer);
                document.addEventListener('keypress', resetTimer);
                document.addEventListener('click', resetTimer);
                resetTimer();
            })();
        </script>
    }
</body>
</html>
