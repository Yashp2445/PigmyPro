<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PigmyPro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            (function() {
                if (!sessionStorage.getItem('pigmypro_tab_initialized')) {
                    window.location.replace('/Auth/Logout');
                    return;
                }

                const authChannel = new BroadcastChannel('pigmypro_tab_auth');
                
                // 1. Check if this is a fresh tab (copy-paste) or a duplicate tab
                if (!sessionStorage.getItem('pigmypro_tab_id')) {
                    sessionStorage.setItem('pigmypro_tab_id', Math.random().toString());
                    authChannel.postMessage('check_active_tab');
                }
                
                let isMaster = false;
                let masterTimer = setTimeout(() => { isMaster = true; }, 300);
                
                authChannel.postMessage('who_is_master');
                
                authChannel.onmessage = function(e) {
                    if (e.data === 'check_active_tab' || e.data === 'who_is_master') {
                        if (isMaster) authChannel.postMessage('i_am_master');
                    } else if (e.data === 'i_am_master') {
                        if (!isMaster) {
                            // Another tab is active. Log this one out.
                            navigator.sendBeacon('/Auth/Logout');
                            window.location.replace('/Auth/Logout');
                        }
                    }
                };

                // 2. Track internal navigation to avoid logging out on normal clicks
                let isInternalNavigation = false;
                document.addEventListener('click', function(e) {
                    const link = e.target.closest('a');
                    if (link && link.href && !link.href.startsWith('javascript:') && link.target !== '_blank') {
                        isInternalNavigation = true;
                    }
                });
                
                document.addEventListener('submit', function() {
                    isInternalNavigation = true;
                });

                // Track F5, Ctrl+R, CMD+R reloads to avoid logging out
                window.addEventListener('keydown', function(e) {
                    if ((e.key === 'F5') || (e.ctrlKey && e.key === 'r') || (e.metaKey && e.key === 'r')) {
                        isInternalNavigation = true;
                    }
                });

                // 3. (Removed beforeunload logout as it breaks native browser refresh)
            })();
        </script>
        <div id="sidebar">
            <div class="sidebar-header">
                <img src="~/Three_Star_Logo-t.png" alt="Three Star Logo" style="height: 32px; width: auto; object-fit: contain;" />
                <span class="logo-text">PigmyPro</span>
            </div>

            <div class="sidebar-nav">
                <div class="nav-section">Application</div>
                <a href="/Dashboard/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-grid-fill"></i> Dashboard
                </a>

                @if (User.IsInRole("SuperAdmin") || User.IsInRole("BankAdmin"))
                {
                    <div class="nav-section">Organization</div>
                    @if (User.IsInRole("SuperAdmin"))
                    {
                        <a href="/Bank/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Bank" ? "active" : "")">
                            <i class="bi bi-bank"></i> Banks
                        </a>
                    }
                    <a href="/Branch/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Branch" ? "active" : "")">
                        <i class="bi bi-diagram-3-fill"></i> Branches
                    </a>
                    <a href="/User/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")">
                        <i class="bi bi-people-fill"></i> System Users
                    </a>
                }

                <div class="nav-section">Banking Masters</div>
                <a href="/Agent/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Agent" ? "active" : "")">
                    <i class="bi bi-person-badge-fill"></i> Collection Agents
                </a>
                @if (ViewBag.HasCBS != 'Y')
                {
                    <a href="/Account/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" ? "active" : "")">
                        <i class="bi bi-wallet2"></i> Customer Accounts
                    </a>
                }
                @if (User.IsInRole("BankAdmin") || User.IsInRole("BranchAdmin"))
                {
                    <a href="/Map/Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Map" ? "active" : "")">
                        <i class="bi bi-geo-alt-fill"></i> Collection Map
                    </a>
                }

                
                @if (User.IsInRole("BankAdmin") || User.IsInRole("BranchAdmin"))
                {
                    <div class="nav-section">Mobile Sync</div>
                  @*   <a href="/MobileImport/Export" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "MobileImport" && ViewContext.RouteData.Values["action"]?.ToString() == "Export" ? "active" : "")">
                        <i class="bi bi-upload"></i> Download Collection Data
                    </a> *@

                    <a href="/MobileImport/Redownload" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "MobileImport" && ViewContext.RouteData.Values["action"]?.ToString() == "Redownload" ? "active" : "")">
                        <i class="bi bi-cloud-download"></i> ReDownload Collection Data
                    </a>
                    
                    @* <a href="/MobileImport/Upload" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "MobileImport" && ViewContext.RouteData.Values["action"]?.ToString() == "Upload" ? "active" : "")">
                        <i class="bi bi-download"></i> Upload Master Account File
                    </a> *@
                }

                <div class="nav-section">Reports</div>
                @{
                    var reportController = ViewContext.RouteData.Values["controller"]?.ToString();
                    var reportAction = ViewContext.RouteData.Values["action"]?.ToString();
                }
                <a href="/Report/DailyCollection" class="nav-link @(reportController == "Report" && reportAction == "DailyCollection" ? "active" : "")">
                    <i class="bi bi-journal-text"></i> Daily Collection
                </a>
                <a href="/Report/AgentSummary" class="nav-link @(reportController == "Report" && reportAction == "AgentSummary" ? "active" : "")">
                    <i class="bi bi-person-lines-fill"></i> Agent Summary
                </a>
               @*  <a href="/Report/Reconciliation" class="nav-link @(reportController == "Report" && reportAction == "Reconciliation" ? "active" : "")">
                    <i class="bi bi-arrow-left-right"></i> Reconciliation
                </a> *@
                @{
                    var psController = ViewContext.RouteData.Values["controller"]?.ToString();
                }
                <a href="/PigmyStatement/Index" class="nav-link @(psController == "PigmyStatement" ? "active" : "")">
                    <i class="bi bi-receipt"></i> Pigmy Statement
                </a>
                <a href="/Audit/Index" class="nav-link @(reportController == "Audit" ? "active" : "")">
                    <i class="bi bi-clock-history"></i> Audit Log
                </a>
            </div>
        </div>

        <div id="main-content">
            <header class="top-navbar">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb m-0">
                        @if (ViewBag.GlobalBankName != null)
                        {
                            <li class='breadcrumb-item active d-flex align-items-center gap-2'>
                                @if (ViewBag.GlobalHasLogo == true)
                                {
                                    <img src='/Bank/GetLogo/@ViewBag.GlobalBankID' style='height:28px; width:auto; border-radius:4px;' onerror="this.style.display='none';" />
                                }
                                <span class='fw-bold text-dark fs-6 m-0'>
                                    @ViewBag.GlobalBankName 
                                </span>
                            </li>
                        }
                        else
                        {
                            @Html.Raw(ViewData["Breadcrumb"] ?? "<li class='breadcrumb-item active'>Dashboard</li>")
                        }
                    </ol>
                </nav>
                <div class="user-info-area">
                    @{
                        var displayName = User.FindFirst("DisplayName")?.Value ?? "User";
                        var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
                        var avatarLetter = !string.IsNullOrEmpty(displayName) ? displayName[0].ToString().ToUpper() : "U";
                        var roleFriendly = userRole switch
                        {
                            "SuperAdmin" => "Super Admin",
                            "BankAdmin" => "Bank Admin",
                            "BranchAdmin" => "Branch Admin",
                            _ => userRole
                        };
                    }
                    <div class="user-info-block">
                        <div class="user-avatar">@avatarLetter</div>
                        <div class="user-info-text">
                            <div class="user-info-name">@displayName</div>
                            <div class="user-info-role">@roleFriendly</div>
                            @if (userRole == "BranchAdmin" && !string.IsNullOrEmpty(ViewBag.GlobalBranchName as string))
                            {
                                <div style="font-size: 0.7rem; color: #d97706; margin-top: 2px; font-weight: 500; opacity: 0.9;">
                                    <i class="bi bi-geo-alt-fill" style="font-size: 0.65rem; margin-right: 3px; opacity: 0.85;"></i>@ViewBag.GlobalBranchName
                                </div>
                            }
                        </div>
                    </div>
                    <div style="width:1px;height:24px;background:var(--color-border);margin:0 8px;"></div>
                    <form asp-controller="Auth" asp-action="Logout" method="post" id="logoutForm" style="margin:0;">
                         @Html.AntiForgeryToken()
                         <button type="submit" class="signout-btn">
                            <i class="bi bi-power"></i> Sign Out
                         </button>
                    </form>
                </div>
            </header>

            <div class="page-body">
                @if (TempData["Success"] != null)
                {
                    <div class="toast-data" data-type="success" data-message="@TempData["Success"]"></div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="toast-data" data-type="error" data-message="@TempData["Error"]"></div>
                }
                @RenderBody()
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <div id="toast-container" class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1055;"></div>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const toastDatas = document.querySelectorAll('.toast-data');
            toastDatas.forEach(data => {
                showToast(data.dataset.message, data.dataset.type);
            });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)

    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            (function () {
                var TIMEOUT_MS = 28 * 60 * 1000; // 28 minutes (warn 2 min before 30min timeout)
                var WARNING_MS = 2 * 60 * 1000;  // 2 minutes to respond
                var timer, warningTimer;

                function resetTimer() {
                    clearTimeout(timer);
                    clearTimeout(warningTimer);
                    timer = setTimeout(showWarning, TIMEOUT_MS);
                }

                function showWarning() {
                    warningTimer = setTimeout(function () { /* session expires naturally */ }, WARNING_MS);
                    if (confirm('Your session will expire in 2 minutes due to inactivity. Click OK to stay logged in.')) {
                        fetch('/Auth/KeepAlive', { credentials: 'same-origin' }).then(function () { resetTimer(); });
                    }
                }

                document.addEventListener('mousemove', resetTimer);
                document.addEventListener('keypress', resetTimer);
                document.addEventListener('click', resetTimer);
                resetTimer();
            })();
        </script>
    }

    @if (User.Identity?.IsAuthenticated == true && ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard")
    {
        <script>
            // Prevent back navigation from Dashboard
            (function () {
                // Push an initial state into the history stack so there is a buffer
                window.history.pushState(null, "", window.location.href);

                // Listen for the popstate event (triggered by Back/Forward buttons)
                window.addEventListener('popstate', function (event) {
                    // Immediately push a new state to overwrite the navigation attempt (prevents quick double-backs)
                    window.history.pushState(null, "", window.location.href);
                    
                    // Trigger a visible refresh so the user understands they are staying on the dashboard
                    // and gets fresh data rather than the page appearing frozen.
                    window.location.reload();
                });
            })();
        </script>
    }
</body>
</html>
