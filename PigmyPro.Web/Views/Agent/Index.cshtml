@model PigmyPro.Web.ViewModels.Agent.AgentIndexVM

@{
    ViewData["Title"] = "Collection Agents";
    ViewData["Breadcrumb"] = "<li class='breadcrumb-item active'>Collection Agent Management</li>";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success d-flex align-items-center" role="alert">
        <i class="bi bi-check-circle-fill me-2 fs-5"></i>
        <div>@TempData["Success"]</div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h4 class="page-title">Collection Agent Management</h4>
        <p class="page-subtitle">Register and manage agents collecting deposits on the field</p>
    </div>
    <a href="/Agent/Create" class="btn btn-primary">
        <i class="bi bi-person-plus-fill"></i> Register Agent
    </a>
</div>

@* ── Filter Panel ── *@
@if (Model.IsSuperAdmin || Model.IsBankAdmin)
{
    <div class="filter-panel">
        <form id="filterForm" method="get" asp-action="Index" class="row g-3 align-items-end">
            @if (Model.IsSuperAdmin)
            {
                <div class="col-md-4">
                    <label class="form-label">Select Bank Tenant</label>
                    <select name="filterBankID" class="form-select" id="filterBankSelect" onchange="this.form.requestSubmit()">
                        <option value="">— Choose Bank —</option>
                        @foreach (var b in Model.BankList!)
                        {
                            <option value="@b.Value" selected="@b.Selected">@b.Text</option>
                        }
                    </select>
                </div>
            }

            @if (Model.IsBankAdmin || (Model.IsSuperAdmin && Model.FilterBankID.HasValue))
            {
                <div class="col-md-4">
                    <label class="form-label">Branch Office</label>
                    <select name="filterBranchCode" class="form-select">
                        <option value="">— All Branches —</option>
                        @foreach (var b in Model.BranchList!)
                        {
                            <option value="@b.Value" selected="@b.Selected">@b.Text</option>
                        }
                    </select>
                </div>

                @if (Model.IsSuperAdmin)
                {
                    <input type="hidden" name="filterBankID" value="@Model.FilterBankID" />
                }

                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-filter"></i> Apply
                    </button>
                </div>
            }

            @if (Model.FilterBankID.HasValue || Model.FilterBranchCode.HasValue)
            {
                <div class="col-auto">
                    <a href="/Agent/Index" class="btn btn-outline">Clear Filters</a>
                </div>
            }
        </form>
    </div>
}

@* ── Table ── *@
<div class="card">
    <div class="card-body p-0">
        @if (!Model.Agents.Items.Any())
        {
            <div class="empty-state py-5">
                <i class="bi bi-person-badge empty-state-icon"></i>
                <div class="empty-state-title">
                    @if (Model.IsSuperAdmin && !Model.FilterBankID.HasValue)
                    {
                        <span>Please select a bank to view associated agents.</span>
                    }
                    else
                    {
                        <span>No Collection agents found for the current selection.</span>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="d-flex justify-content-end p-3 border-bottom bg-light">
                <div class="input-group" style="max-width: 300px;">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="agentSearch" class="form-control border-start-0" placeholder="Search agents..." />
                </div>
            </div>
            <div class="table-wrapper">
                <div class="table-responsive">
                    <table class="table" id="agentTable">
                    <thead>
                        <tr>
                            <th class="sortable">Agent Details</th>
                            @if (Model.IsSuperAdmin)
                            {
                                <th class="sortable">Bank</th>
                            }
                            <th class="sortable">Branch</th>
                            <th class="sortable">Configuration</th>
                            <th class="text-center sortable">Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var agent in Model.Agents.Items)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold cell-truncate" title="@agent.Name">@agent.Name</div>
                                    <div class="text-muted" style="font-size: 12px;">
                                        <span class="mono-data">#@agent.Code.ToString("0")</span> &bull; <i class="bi bi-phone"></i> @(agent.MobileNo ?? "N/A")
                                    </div>
                                </td>

                                @if (Model.IsSuperAdmin)
                                {
                                    <td class="text-muted">
                                        <div class="cell-truncate" title="@agent.BankName">@agent.BankName</div>
                                    </td>
                                }

                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-building text-primary"></i>
                                        <span class="cell-truncate" title="@agent.BranchName">@agent.BranchName</span>
                                    </div>
                                </td>

                                <td>
                                    <div style="font-size: 12px; color: var(--color-text-muted);">
                                        <div class="mb-1"><i class="bi bi-cash-stack me-1"></i>Cash Ready: <span class="fw-bold">@(agent.ReadyToCash ? "Yes" : "No")</span></div>
                                        <div><i class="bi bi-calendar-x me-1"></i>Holidays: <span class="fw-bold">@agent.Holidays</span></div>
                                    </div>
                                </td>

                                <td class="text-center">
                                    @if (!agent.IsBlocked)
                                    {
                                        <span class="badge badge-success">ACTIVE</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">BLOCKED</span>
                                    }
                                </td>

                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/Agent/Edit?code=@agent.Code&bankId=@agent.BankID&branchCode=@agent.BranchCode" class="btn btn-outline btn-sm">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <button type="button" class="btn btn-outline btn-sm text-danger" onclick="confirmDelete(@agent.Code, @agent.BankID, @agent.BranchCode, '@agent.Name')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            </div>
            <div class="card-footer bg-white border-top p-3 d-flex justify-content-between align-items-center">
                <div class="text-muted" style="font-size: 13px;">
                    Showing @(Model.Agents.Items.Any() ? ((Model.Agents.PageNumber - 1) * Model.Agents.PageSize) + 1 : 0) to @(Math.Min(Model.Agents.PageNumber * Model.Agents.PageSize, Model.Agents.TotalCount)) of @Model.Agents.TotalCount entries
                </div>
                <div class="btn-group">
                    <button type="submit" form="filterForm" name="page" value="@(Model.Agents.PageNumber - 1)" class="btn btn-outline btn-sm" @(Model.Agents.PageNumber <= 1 ? "disabled" : "")>
                        <i class="bi bi-chevron-left"></i> Previous
                    </button>
                    <span class="btn btn-outline btn-sm disabled" style="color: var(--color-text-primary); border-color: var(--color-border);">Page @Model.Agents.PageNumber of @(Model.Agents.TotalPages > 0 ? Model.Agents.TotalPages : 1)</span>
                    <button type="submit" form="filterForm" name="page" value="@(Model.Agents.PageNumber + 1)" class="btn btn-outline btn-sm" @(Model.Agents.PageNumber >= Model.Agents.TotalPages ? "disabled" : "")>
                        Next <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@* Delete modal *@
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center p-5">
                <div class="mb-4 text-danger">
                    <i class="bi bi-person-x" style="font-size: 64px;"></i>
                </div>
                <h4 class="fw-bold mb-2" style="color: var(--color-text-primary);">De-register Agent?</h4>
                <p id="deleteMsg" class="text-muted mb-4"></p>

                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="code" id="deleteCode" />
                    <input type="hidden" name="bankId" id="deleteBankId" />
                    <input type="hidden" name="branchCode" id="deleteBranchCode" />
                    <div class="d-flex gap-3 justify-content-center">
                        <button type="button" class="btn btn-outline" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger px-4">Confirm Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(code, bankId, branchCode, name) {
            document.getElementById('deleteMsg').textContent = 'Are you sure you want to permanently remove Collection agent "' + name + '"? This action cannot be undone.';
            document.getElementById('deleteCode').value = code;
            document.getElementById('deleteBankId').value = bankId;
            document.getElementById('deleteBranchCode').value = branchCode;
            document.getElementById('deleteForm').action = '/Agent/Delete';
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }

        document.addEventListener('DOMContentLoaded', () => {
            setupTableSortAndSearch('agentTable', 'agentSearch');
        });
    </script>
}