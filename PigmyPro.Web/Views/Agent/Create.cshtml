@model PigmyPro.Web.ViewModels.Agent.AgentCreateEditVM

@{
    var isEdit = Model.IsEdit;
    ViewData["Title"] = isEdit ? "Update Agent" : "Register Agent";
    ViewData["Breadcrumb"] = $"<li class='breadcrumb-item'><a href='/Agent/Index'>Collection Agents</a></li><li class='breadcrumb-item active'>{(isEdit ? "Update" : "Register")}</li>";
}

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-7">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">
                    <i class="bi bi-person-badge text-primary me-2"></i>
                    @(isEdit ? "Edit Agent Details" : "Collection Agent Registration")
                </h5>
            </div>

            <div class="card-body">
                <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="IsSuperAdmin" />
                    <input type="hidden" asp-for="IsBankAdmin" />

                    @if (Model.IsSuperAdmin)
                    {
                        <div class="mb-3">
                            <label class="form-label">Bank</label>
                            <select asp-for="SelectedBankID" asp-items="Model.BankList"
                                    class="form-select" id="bankSelect"
                                    onchange="loadBranches(this.value)">
                                <option value="">— Select Bank —</option>
                            </select>
                            <span asp-validation-for="SelectedBankID" class="text-danger small"></span>
                        </div>
                    }

                    @if (Model.IsSuperAdmin || Model.IsBankAdmin)
                    {
                        <div class="mb-3">
                            <label class="form-label">Assigned Branch</label>
                            <select asp-for="BranchCode" asp-items="Model.BranchList"
                                    class="form-select" id="branchSelect"
                                    onchange="onBranchChanged(this.value)">
                                <option value="">— Select Branch —</option>
                            </select>
                            <span asp-validation-for="BranchCode" class="text-danger small"></span>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" asp-for="BranchCode" />
                    }

                    @if (Model.IsBankAdmin)
                    {
                        <input type="hidden" id="currentBankId" value="@Model.SelectedBankID" />
                    }

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label asp-for="Code" class="form-label">Agent Code</label>
                            <input asp-for="Code" id="agentCodeInput" class="form-control"
                                   style="background-color: var(--color-bg-elevated);"
                                   readonly
                                   placeholder="@(isEdit ? "" : "Select a branch...")" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="NAME" class="form-label">Full Name</label>
                            <input asp-for="NAME" class="form-control" placeholder="Full name of agent" />
                            <span asp-validation-for="NAME" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-7">
                            <label asp-for="MobileNo" class="form-label">Mobile Number</label>
                            <input asp-for="MobileNo" class="form-control"
                                   type="tel"
                                   inputmode="numeric"
                                   maxlength="10"
                                   pattern="[6-9][0-9]{9}"
                                   placeholder="10-digit mobile number"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);" />
                            <span asp-validation-for="MobileNo" class="text-danger small"></span>
                        </div>
                        <div class="col-md-5">
                            <label asp-for="NoOfHolidays" class="form-label">Holidays/Month</label>
                            <input asp-for="NoOfHolidays" type="number" min="0" class="form-control" placeholder="0" />
                        </div>
                    </div>

                    <div class="mb-4 pt-3 border-top">
                        <h6 class="form-label" style="font-size: 13px; color: var(--color-text-primary); margin-bottom: 12px;">Business Rules</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-control d-flex align-items-center gap-3 py-3">
                                    <div class="form-check form-switch m-0">
                                        <input asp-for="Block" class="form-check-input" type="checkbox" id="blockToggle" />
                                    </div>
                                    <label class="form-check-label fw-bold" for="blockToggle" style="font-size: 12px; cursor: pointer;">
                                        Block Account
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-control d-flex align-items-center gap-3 py-3">
                                    <div class="form-check form-switch m-0">
                                        <input asp-for="ReadyToCash" class="form-check-input" type="checkbox" id="readyToCashToggle" />
                                    </div>
                                    <label class="form-check-label fw-bold" for="readyToCashToggle" style="font-size: 12px; cursor: pointer;">
                                        Ready to Cash
                                    </label>
                                </div>
                            </div>
                        </div>

                        @* Block remark — shown whenever the Block toggle is on, whether blocking or unblocking *@
                        <div class="mt-3" id="blockRemarkWrapper" style="display: @(Model.Block ? "block" : "none");">
                            <label asp-for="BlockRemark" class="form-label">Block / Unblock Remark</label>
                            <input asp-for="BlockRemark" class="form-control" maxlength="150" placeholder="Reason for block status change" />
                        </div>

                        @* Reset is Edit-only — there's no existing row to reset on Create *@
                        @if (isEdit)
                        {
                            <div class="mt-3 pt-3 border-top">
                                <div class="form-control d-flex align-items-center gap-3 py-3">
                                    <div class="form-check form-switch m-0">
                                        <input asp-for="ResetAgent" class="form-check-input" type="checkbox" id="resetToggle" />
                                    </div>
                                    <label class="form-check-label fw-bold" for="resetToggle" style="font-size: 12px; cursor: pointer;">
                                        Reset Agent (clears mobile number &amp; resets password)
                                    </label>
                                </div>
                                <div class="mt-2" id="resetRemarkWrapper" style="display: none;">
                                    <label asp-for="ResetRemark" class="form-label">Reset Remark</label>
                                    <input asp-for="ResetRemark" class="form-control" maxlength="150" placeholder="Reason for reset" />
                                </div>
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg"></i>
                            @(isEdit ? "Update Agent" : "Register Agent")
                        </button>
                        <a href="/Agent/Index" class="btn btn-outline px-4">Cancel</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Show/hide the Block remark box based on the Block toggle
        document.getElementById('blockToggle').addEventListener('change', function () {
            document.getElementById('blockRemarkWrapper').style.display = this.checked ? 'block' : 'none';
        });

        @if (isEdit)
        {
                <text>
                    // Show/hide the Reset remark box based on the Reset toggle
                    document.getElementById('resetToggle').addEventListener('change', function () {
                        document.getElementById('resetRemarkWrapper').style.display = this.checked ? 'block' : 'none';
                    });
                </text>
        }
    </script>

    @if (!isEdit)
    {
        <script>
            function fetchNextCode(bankId, branchCode) {
                const codeInput = document.getElementById('agentCodeInput');
                if (!bankId || !branchCode) {
                    codeInput.value = '';
                    return;
                }
                fetch('/Agent/GetNextCode?bankId=' + bankId + '&branchCode=' + branchCode)
                    .then(r => r.json())
                    .then(data => { codeInput.value = data.code; });
            }

            function onBranchChanged(branchCode) {
                @if (Model.IsSuperAdmin)
                {
                            <text>
                                    const bankId = document.getElementById('bankSelect').value;
                                    fetchNextCode(bankId, branchCode);
                            </text>
                }
                else if (Model.IsBankAdmin)
                {
                            <text>
                                    const bankId = document.getElementById('currentBankId').value;
                                    fetchNextCode(bankId, branchCode);
                            </text>
                }
            }

            @if (Model.IsSuperAdmin)
            {
                        <text>
                                function loadBranches(bankId) {
                                    const branchSelect = document.getElementById('branchSelect');
                                    branchSelect.innerHTML = '<option value="">— Select Branch —</option>';
                                    document.getElementById('agentCodeInput').value = '';
                                    if (!bankId) return;

                                    fetch('/Agent/GetBranches?bankId=' + bankId)
                                        .then(r => r.json())
                                        .then(branches => {
                                            branches.forEach(b => {
                                                const opt = document.createElement('option');
                                                opt.value = b.value;
                                                opt.textContent = b.text;
                                                branchSelect.appendChild(opt);
                                            });
                                        });
                                }
                        </text>
            }
        </script>
    }
}
