@model IEnumerable<PigmyPro.Web.ViewModels.Bank.BankListVM>

@{
    ViewData["Title"] = "Banks";
    ViewData["Breadcrumb"] = "<li class='breadcrumb-item active'>Bank Directory</li>";
}

@using PigmyPro.Web.ViewModels.Shared

@{
    var headerSubtitle = ViewBag.IsSuperAdmin == true ? "Manage organizational bank tenants" : "Your organization details";
    var actions = ViewBag.IsSuperAdmin == true ? @"<a href=""/Bank/Create"" class=""btn btn-primary""><i class=""bi bi-plus-lg""></i> New Bank</a>" : "";
    var header = new PageHeaderVM {
        Title = "Bank Directory",
        Subtitle = headerSubtitle,
        ActionsHtml = actions
    };
}
<partial name="_PageHeader" model="header" />

<div class="card elevated border-0">
    <div class="card-body p-0">
        <div class="table-container border-0">
            <div class="table-responsive">
                <table class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Logo</th>
                        <th>Bank Name</th>
                        <th>Status</th>
                        <th>Features</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bank in Model)
                    {
                        <tr>
                            <td class="mono-data fw-bold text-muted">#@bank.BankID</td>
                            <td>
                                @if (bank.HasLogo)
                                {
                                    <img src="/Bank/GetLogo?id=@bank.BankID" alt="Logo" style="max-height: 30px;" class="border rounded" />
                                }
                                else
                                {
                                    <i class="bi bi-bank text-muted fs-4"></i>
                                }
                            </td>
                            <td class="fw-bold">
                                <div class="cell-truncate" title="@bank.Name">@bank.Name</div>
                            </td>
                            <td>
                                @if (bank.ActiveYN)
                                {
                                    <span class="badge badge-success">ACTIVE</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">SUSPENDED</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-1">
                                    @if (bank.HasCBS)
                                    {
                                        <span class="badge bg-primary" style="width: fit-content;">CBS</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary text-white" style="width: fit-content;">Non-CBS</span>
                                    }
                                    
                                    @if (bank.RecieptPrinting)
                                    {
                                        <span class="badge bg-info text-dark" style="width: fit-content;">Receipt Printing</span>
                                    }
                                </div>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a href="/Bank/Edit/@bank.BankID" class="btn btn-sm btn-outline">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    @if(bank.CanDelete)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline text-danger border-danger" onclick="confirmDelete(@bank.BankID, '@bank.Name')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline text-muted border-muted" style="cursor: not-allowed; opacity: 0.65;" onclick="showDependencyError('This bank cannot be deleted because it still has @bank.DependentBranchCount active branch(es). Please remove all branches first.')" title="Cannot delete: @bank.DependentBranchCount active branch(es) exist">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function showDependencyError(message) {
            Swal.fire({
                icon: 'warning',
                title: 'Cannot Delete',
                text: message,
                confirmButtonColor: '#2563eb'
            });
        }

        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Confirm Deletion',
                text: 'Are you sure you want to remove "' + name + '"? This will affect all associated branches and agents.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Delete Bank'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.createElement('form');
                    form.method = 'post';
                    form.action = '/Bank/Delete/' + id;
                    
                    const token = document.createElement('input');
                    token.type = 'hidden';
                    token.name = '__RequestVerificationToken';
                    token.value = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    
                    form.appendChild(token);
                    document.body.appendChild(form);
                    form.submit();
                }
            });
        }
    </script>
}

