@model PigmyPro.Web.ViewModels.Bank.BankCreateEditVM

@{
    var isEdit = Model.BankID > 0;
    ViewData["Title"] = isEdit ? "Modify Bank" : "New Bank";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0" style="border-radius:12px;">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-dark">
                    @(isEdit ? "Update Bank" : "Bank Registration")
                </h5>
            </div>

            <div class="card-body p-4">
                <form asp-action="@(isEdit ? "Edit" : "Create")" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    @if (isEdit)
                    {
                        <input type="hidden" asp-for="BankID" />
                    }

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-8">
                            <label asp-for="Name" class="form-label fw-bold"></label>
                            <input asp-for="Name" class="form-control" maxlength="300" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-12 col-md-4">
                            <label asp-for="AppLoginPrefix" class="form-label fw-bold"></label>
                            <input asp-for="AppLoginPrefix" class="form-control" placeholder="e.g. B001" maxlength="4" />
                            <span asp-validation-for="AppLoginPrefix" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-bold"></label>
                        <textarea asp-for="Address" class="form-control" rows="2" maxlength="600"></textarea>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6">
                            <label asp-for="ContactPerson" class="form-label fw-bold"></label>
                            <input asp-for="ContactPerson" class="form-control" maxlength="200" />
                            <span asp-validation-for="ContactPerson" class="text-danger"></span>
                        </div>
                        <div class="col-12 col-md-6">
                            <label asp-for="ContactNo" class="form-label fw-bold"></label>
                            <input asp-for="ContactNo" class="form-control" maxlength="10" oninput="validateMobile(this)" />
                            <span asp-validation-for="ContactNo" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6">
                            <label asp-for="EmailID" class="form-label fw-bold"></label>
                            <input asp-for="EmailID" class="form-control" type="email" maxlength="200" />
                            <span asp-validation-for="EmailID" class="text-danger"></span>
                        </div>
                        <div class="col-12 col-md-6">
                            <label asp-for="No_of_Holidays" class="form-label fw-bold"></label>
                            <input asp-for="No_of_Holidays" class="form-control" type="number" min="0" max="99" oninput="validateHolidays(this)" />
                            <span asp-validation-for="No_of_Holidays" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6 d-flex align-items-center mt-4">
                            <div class="form-check me-4">
                                <input asp-for="ActiveYN" class="form-check-input" type="checkbox" />
                                <label asp-for="ActiveYN" class="form-check-label">Active</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="HasCBS" class="form-check-input" type="checkbox" />
                                <label asp-for="HasCBS" class="form-check-label">Has CBS</label>
                            </div>
                            <div class="form-check ms-4">
                                <input asp-for="RecieptPrinting" class="form-check-input" type="checkbox" />
                                <label asp-for="RecieptPrinting" class="form-check-label">Receipt Printing</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LogoFile" class="form-label fw-bold"></label>
                        <input asp-for="LogoFile" type="file" class="form-control" accept="image/png, image/jpeg" />
                        <span asp-validation-for="LogoFile" class="text-danger"></span>
                        
                        @if (isEdit && Model.HasExistingLogo)
                        {
                            <div class="mt-2">
                                <img src="/Bank/GetLogo?id=@Model.BankID" alt="Current Logo" style="max-height: 50px;" class="border rounded p-1 mb-2" />
                                <input type="hidden" asp-for="HasExistingLogo" />
                                <div class="form-check">
                                    <input asp-for="RemoveLogo" class="form-check-input" type="checkbox" />
                                    <label asp-for="RemoveLogo" class="form-check-label text-danger">Remove current logo</label>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mb-4">
                        <label class="fw-bold">Collection Type</label>

                        <div class="border p-3">

                            <div class="form-check">
                                <input type="checkbox" checked disabled />
                                <label>Pigmy</label>
                            </div>
                            <input type="hidden" asp-for="IsPigmy" value="true" />

                            <div class="form-check">
                                <input asp-for="IsLoan" type="checkbox" id="cbLoan" />
                                <label asp-for="IsLoan">Loan</label>
                            </div>

                            <div class="form-check">
                                <input asp-for="IsRecurring" type="checkbox" id="cbRecurring" />
                                <label asp-for="IsRecurring">Recurring</label>
                            </div>

                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        Save
                    </button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">
                        Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const loan = document.getElementById("cbLoan");
        const recurring = document.getElementById("cbRecurring");

        recurring.addEventListener("change", function () {
            if (recurring.checked && !loan.checked) {
                loan.checked = true;
            }
        });

        loan.addEventListener("change", function () {
            if (!loan.checked && recurring.checked) {
                recurring.checked = false;
            }
        });

        function validateMobile(input) {
            // Remove non-digits
            input.value = input.value.replace(/\D/g, '').slice(0, 10);
            
            const val = input.value;
            let errorMsg = '';
            
            if (val.length > 0 && val.length < 10) {
                errorMsg = 'Must be exactly 10 digits';
            } else if (val.length === 10) {
                if (val[0] < '6' || val[0] > '9') {
                    errorMsg = 'Must start with 6-9';
                } else if (/^([0-9])\1{9}$/.test(val)) {
                    errorMsg = 'Cannot be all same digits';
                } else if ("0123456789 9876543210".includes(val)) {
                    errorMsg = 'Cannot be sequential numbers';
                }
            }
            
            input.setCustomValidity(errorMsg);
            
            // Show custom error if any, otherwise let unobtrusive validation handle it
            let unobtrusiveSpan = input.nextElementSibling;
            if (unobtrusiveSpan && unobtrusiveSpan.tagName === 'SPAN') {
                if (errorMsg) {
                    unobtrusiveSpan.textContent = errorMsg;
                    unobtrusiveSpan.className = 'text-danger field-validation-error';
                } else {
                    unobtrusiveSpan.textContent = '';
                    unobtrusiveSpan.className = 'text-danger field-validation-valid';
                }
            }
        }

        function validateHolidays(input) {
            // Remove non-digits
            input.value = input.value.replace(/\D/g, '');
            // Restrict to max 99
            if (parseInt(input.value) > 99) {
                input.value = "99";
            }
        }
    </script>
}
