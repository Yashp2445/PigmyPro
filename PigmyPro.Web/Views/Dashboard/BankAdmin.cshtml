@model PigmyPro.Web.ViewModels.Dashboard.BankAdminDashboardVM

@{
    ViewData["Title"] = "BankAdmin Dashboard";
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h4 class="page-title mb-0">Bank Overview</h4>
        <p class="page-subtitle mb-0">Operational metrics for your banking organization</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <a href="javascript:window.location.reload();" class="btn btn-outline-primary btn-sm d-flex align-items-center gap-2">
            <i class="bi bi-arrow-clockwise"></i> 
            <span>Refresh Data</span>
        </a>
    </div>
</div>

<!-- Filter Panel -->
<div class="filter-panel">
    <form asp-action="BankAdmin" method="get" class="row g-3 align-items-end">
        <div class="col-md-6">
            <label class="form-label">Branch</label>
            <select name="branchId" class="form-select">
                <option value="">All Branches</option>
                @foreach (var branch in Model.Branches)
                {
                    <option value="@branch.Value" selected="@(branch.Value == Model.FilterBranchID?.ToString())">@branch.Text</option>
                }
            </select>
        </div>
        <div class="col-md-auto d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4"><i class="bi bi-funnel-fill"></i> Apply</button>
            <a href="/Dashboard/BankAdmin" class="btn btn-outline">Clear</a>
        </div>
    </form>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="stat-card info stat-card-compact h-100 d-flex">
            <div class="stat-icon mb-0 me-3 rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:40px; height:40px; font-size:1.2rem; box-shadow: inset 0 1px 1px rgba(255,255,255,0.4), 0 2px 6px rgba(14,165,233,0.15);"><i class="bi bi-diagram-3-fill"></i></div>
            <div>
                <div class="stat-value" style="font-size:1.25rem; font-weight:700; line-height:1.1;">@Model.TotalBranches</div>
                <div class="stat-label" style="font-size:0.75rem; margin-top:4px; font-weight:600; text-transform:uppercase; letter-spacing:0.3px;">Active Branches</div>
            </div>
        </div>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="stat-card warning stat-card-compact h-100 d-flex">
            <div class="stat-icon mb-0 me-3 rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:40px; height:40px; font-size:1.2rem; box-shadow: inset 0 1px 1px rgba(255,255,255,0.4), 0 2px 6px rgba(217,119,6,0.15);"><i class="bi bi-person-badge-fill"></i></div>
            <div>
                <div class="stat-value" style="font-size:1.25rem; font-weight:700; line-height:1.1;">@Model.TotalAgents</div>
                <div class="stat-label" style="font-size:0.75rem; margin-top:4px; font-weight:600; text-transform:uppercase; letter-spacing:0.3px;">Total Active Agents</div>
            </div>
        </div>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="stat-card success stat-card-compact h-100 d-flex">
            <div class="stat-icon mb-0 me-3 rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:40px; height:40px; font-size:1.2rem; box-shadow: inset 0 1px 1px rgba(255,255,255,0.4), 0 2px 6px rgba(22,163,74,0.15);"><i class="bi bi-wallet2"></i></div>
            <div>
                <div class="stat-value" style="font-size:1.25rem; font-weight:700; line-height:1.1;">@Model.TotalAccounts.ToString("N0")</div>
                <div class="stat-label" style="font-size:0.75rem; margin-top:4px; font-weight:600; text-transform:uppercase; letter-spacing:0.3px;">Total Accounts</div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="stat-card h-100 d-flex flex-column justify-content-center" style="padding: 16px 20px !important; background: linear-gradient(135deg, #d97706 0%, #78350f 100%); border: none; color: white; box-shadow: 0 4px 12px rgba(217,119,6,0.25); overflow: hidden; position: relative;">
            <i class="bi bi-cash-stack" style="position: absolute; right: -5%; bottom: -15%; font-size: 5.5rem; opacity: 0.08; transform: rotate(-10deg); pointer-events:none;"></i>
            <div class="d-flex justify-content-between align-items-start mb-2 position-relative z-1">
                <div class="stat-label fw-bold" style="color:rgba(255,255,255,0.85); text-transform: uppercase; letter-spacing: 0.5px; font-size:0.7rem; margin-top:0;">Pending with Agents</div>
                <div class="stat-icon rounded-circle mb-0 d-flex align-items-center justify-content-center flex-shrink-0" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); border: 1px solid rgba(255,255,255,0.25); color: white; font-size:0.9rem; width:28px; height:28px; box-shadow: 0 2px 6px rgba(0,0,0,0.15); margin-left:8px;"><i class="bi bi-cash-stack"></i></div>
            </div>
            <div class="stat-value fw-bolder mb-1 position-relative z-1" style="color:white; font-size:1.45rem; line-height:1;">₹@(Model.CollectionHeld?.TotalAmount.ToString("N2") ?? "0.00")</div>
            <div class="d-flex align-items-center gap-3 position-relative z-1" style="color:rgba(255,255,255,0.75); font-size:0.75rem; font-weight:500;">
                <div><i class="bi bi-person-fill me-1"></i>@(Model.CollectionHeld?.AgentCount ?? 0) Agents</div>
                <div><i class="bi bi-person-check-fill me-1"></i>@(Model.AcMasterData?.TotalCollectionAccounts.ToString("N0") ?? "0") A/Cs</div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="stat-card h-100 d-flex flex-column justify-content-center" style="padding: 16px 20px !important; background: linear-gradient(135deg, #059669 0%, #064e3b 100%); border: none; color: white; box-shadow: 0 4px 12px rgba(5,150,105,0.25); overflow: hidden; position: relative;">
            <i class="bi bi-check-circle-fill" style="position: absolute; right: -5%; bottom: -15%; font-size: 5.5rem; opacity: 0.08; transform: rotate(-10deg); pointer-events:none;"></i>
            <div class="d-flex justify-content-between align-items-start mb-2 position-relative z-1">
                <div class="stat-label fw-bold" style="color:rgba(255,255,255,0.85); text-transform: uppercase; letter-spacing: 0.5px; font-size:0.7rem; margin-top:0;">Deposited Today</div>
                <div class="stat-icon rounded-circle mb-0 d-flex align-items-center justify-content-center flex-shrink-0" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); border: 1px solid rgba(255,255,255,0.25); color: white; font-size:0.9rem; width:28px; height:28px; box-shadow: 0 2px 6px rgba(0,0,0,0.15); margin-left:8px;"><i class="bi bi-check-circle-fill"></i></div>
            </div>
            <div class="stat-value fw-bolder mb-1 position-relative z-1" style="color:white; font-size:1.45rem; line-height:1;">₹@(Model.CollectionDeposited?.TotalAmount.ToString("N2") ?? "0.00")</div>
            <div class="d-flex align-items-center gap-3 position-relative z-1" style="color:rgba(255,255,255,0.75); font-size:0.75rem; font-weight:500;">
                <div><i class="bi bi-person-fill me-1"></i>@(Model.CollectionDeposited?.AgentCount ?? 0) Agents</div>
            </div>
        </div>
    </div>
</div>

<!-- Agent Registry Tables -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="card-title m-0"><i class="bi bi-people me-2"></i>Agent Registry</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-wrapper">
                    <div class="table-responsive">
                        <table class="table mb-0 table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Agent Name</th>
                                    <th>Branch</th>
                                    <th>Mobile No</th>
                                    <th class="text-center">Status</th>
                                    <th class="text-end">Collection</th>
                                    <th class="text-center">Accounts</th>
                                    <th class="text-center">Days Inactive</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.AgentOverview.Any())
                                {
                                    @foreach (var agent in Model.AgentOverview)
                                    {
                                        <tr>
                                            <td class="mono-data">@agent.AgentCode</td>
                                            <td class="fw-bold">
                                                <div class="cell-truncate" title="@agent.AgentName">@agent.AgentName</div>
                                            </td>
                                            <td class="text-muted">
                                                <div class="cell-truncate" title="@agent.BranchName">@agent.BranchName</div>
                                            </td>
                                            <td class="mono-data">@agent.MobileNumber</td>
                                            <td class="text-center">
                                                @if (agent.IsBlocked)
                                                {
                                                    <span class="badge badge-danger">BLOCKED</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-success">ACTIVE</span>
                                                }
                                            </td>
                                            <td class="text-end fw-bold text-primary mono-data">₹@agent.TodayAmount.ToString("N2")</td>
                                            <td class="text-center mono-data">@agent.AccountsCollected</td>
                                            <td class="text-center mono-data @(agent.DaysInactive > 7 ? "text-danger fw-bold" : "")">@(agent.DaysInactive.HasValue ? agent.DaysInactive.Value.ToString() : "N/A")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="8">
                                            <div class="empty-state">
                                                <i class="bi bi-people empty-state-icon"></i>
                                                <div class="empty-state-title">No agents found</div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Trend Line Chart & At-Risk Agents -->
<div class="row g-4 mb-4">
    <div class="col-lg-12">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="card-title">Collection Trend</h5>
            </div>
            <div class="card-body">
                <div style="position:relative; height:320px;">
                    <canvas id="collectionTrendChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Branch-wise Table + Bar Chart -->
<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">Branch-wise Performance</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-wrapper">
                    <div class="table-responsive">
                        <table class="table">
                        <thead>
                            <tr>
                                <th>Branch Name</th>
                                <th class="text-center">Agents</th>
                                <th class="text-center">Accounts</th>
                                <th class="text-end">Collection</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.BranchWiseData.Any())
                            {
                                @foreach (var branch in Model.BranchWiseData)
                                {
                                    <tr>
                                        <td class="fw-bold">
                                            <div class="cell-truncate" title="@branch.BranchName">@branch.BranchName</div>
                                        </td>
                                        <td class="text-center mono-data">@branch.AgentCount</td>
                                        <td class="text-center mono-data">@branch.AccountCount.ToString("N0")</td>
                                        <td class="text-end fw-bold text-primary mono-data">
                                            @if (branch.TodayCollection > 0)
                                            {
                                                <span>₹@branch.TodayCollection.ToString("N2")</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted" style="opacity:0.6;">₹0.00</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4">
                                        <div class="empty-state">
                                            <i class="bi bi-database-exclamation empty-state-icon"></i>
                                            <div class="empty-state-title">No branch activity recorded</div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        @if (Model.BranchWiseData.Any())
                        {
                            <tfoot style="background: var(--color-bg-elevated); font-weight: 700;">
                                <tr>
                                    <td style="padding: 14px 20px;">Bank Total</td>
                                    <td class="text-center mono-data">@Model.BranchWiseData.Sum(x => x.AgentCount)</td>
                                    <td class="text-center mono-data">@Model.BranchWiseData.Sum(x => x.AccountCount).ToString("N0")</td>
                                    <td class="text-end text-primary mono-data">₹@Model.BranchWiseData.Sum(x => x.TodayCollection).ToString("N2")</td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="chart-card h-100">
            <h5 class="chart-title">Collection Distribution</h5>
            <div style="position:relative; height:320px;">
                <canvas id="branchBarChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Top Agents Table + Pie Chart -->
<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">Top Collection Agents</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-wrapper">
                    <div class="table-responsive">
                        <table class="table">
                        <thead>
                            <tr>
                                <th>Rank</th>
                                <th>Agent Name</th>
                                <th>Branch</th>
                                <th class="text-center">Txns</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopAgents.Any())
                            {
                                var rank = 0;
                                @foreach (var agent in Model.TopAgents)
                                {
                                    rank++;
                                    <tr>
                                        <td class="mono-data fw-bold text-muted">#@rank</td>
                                        <td class="fw-bold">
                                            <div class="cell-truncate" title="@agent.AgentName">@agent.AgentName</div>
                                        </td>
                                        <td class="text-muted">
                                            <div class="cell-truncate" title="@agent.BranchName">@agent.BranchName</div>
                                        </td>
                                        <td class="text-center mono-data">@agent.AccountsCollected</td>
                                        <td class="text-end fw-bold text-primary mono-data">₹@agent.TodayAmount.ToString("N2")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5">
                                        <div class="empty-state">
                                            <i class="bi bi-person-exclamation empty-state-icon"></i>
                                            <div class="empty-state-title">No agent data available</div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card h-100 border-warning border-opacity-50">
            <div class="card-header bg-warning bg-opacity-10">
                <h5 class="card-title text-warning-emphasis m-0"><i class="bi bi-exclamation-triangle me-2"></i>At-Risk Agents</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.AtRiskAgents.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var agent in Model.AtRiskAgents)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                                <div>
                                    <div class="fw-bold cell-truncate" title="@agent.AgentName">@agent.AgentName</div>
                                    <div class="text-muted small cell-truncate" title="@agent.BranchName">@agent.BranchName</div>
                                </div>
                                <span class="badge badge-danger">@agent.DaysInactive Days Inactive</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="empty-state p-4 h-100 d-flex flex-column justify-content-center">
                        <i class="bi bi-check-circle empty-state-icon text-success" style="opacity:0.5;"></i>
                        <div class="empty-state-title">All agents active</div>
                        <p class="empty-state-subtitle">No agents inactive for > 7 days</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var brandColor = '#3b82f6';
            var chartColors = ['#3b82f6', '#0ea5e9', '#16a34a', '#d97706', '#7c3aed', '#dc2626', '#0891b2', '#be185d'];
            var tooltipBg = '#111827';
            var mutedText = '#9ca3af';

            // Bar Chart
            var barLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.BranchWiseData.Select(x => x.BranchName)));
            var barData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.BranchWiseData.Select(x => x.TodayCollection)));

            new Chart(document.getElementById('branchBarChart').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: barLabels,
                    datasets: [{
                        label: "Collection",
                        data: barData,
                        backgroundColor: brandColor,
                        borderRadius: 6,
                        maxBarThickness: 40
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: tooltipBg, padding: 12,
                            titleFont: { family: 'Inter', size: 13, weight: '700' },
                            bodyFont: { family: 'JetBrains Mono', size: 12 },
                            cornerRadius: 8, displayColors: false,
                            callbacks: { label: function (ctx) { return '₹' + ctx.parsed.y.toLocaleString('en-IN'); } }
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { font: { family: 'Inter', size: 11 }, color: mutedText }
                        },
                        y: {
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            ticks: {
                                font: { family: 'Inter', size: 11 }, color: mutedText,
                                callback: function(v) { return '₹' + (v >= 1000 ? (v/1000).toFixed(1) + 'k' : v); }
                            }
                        }
                    }
                }
            });

            // Trend Chart
            var trendLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyTrendData.Select(x => x.Date.ToString("dd MMM"))));
            var trendData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyTrendData.Select(x => x.Amount)));

            new Chart(document.getElementById('collectionTrendChart').getContext('2d'), {
                type: 'line',
                data: {
                    labels: trendLabels,
                    datasets: [{
                        label: 'Collection',
                        data: trendData,
                        borderColor: '#3b82f6',
                        backgroundColor: 'rgba(59, 130, 246, 0.1)',
                        borderWidth: 2,
                        tension: 0.4,
                        fill: true,
                        pointBackgroundColor: '#3b82f6',
                        pointBorderColor: '#fff',
                        pointHoverBackgroundColor: '#fff',
                        pointHoverBorderColor: '#3b82f6'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: tooltipBg,
                            padding: 12,
                            titleFont: { family: 'Inter', size: 13, weight: '700' },
                            bodyFont: { family: 'JetBrains Mono', size: 12 },
                            cornerRadius: 8,
                            displayColors: false,
                            callbacks: { label: function(ctx) { return '₹' + ctx.parsed.y.toLocaleString('en-IN'); } }
                        }
                    },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { family: 'Inter', size: 11 }, color: mutedText } },
                        y: { 
                            grid: { color: 'rgba(0,0,0,0.05)' }, 
                            ticks: { 
                                font: { family: 'Inter', size: 11 }, color: mutedText,
                                callback: function(v) { return '₹' + (v >= 1000 ? (v/1000).toFixed(1) + 'k' : v); }
                            } 
                        }
                    }
                }
            });
            


        })();
    </script>
}

