@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Password Reset Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">Password Reset Requests</h1>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}



<div class="card shadow mb-4 border-0" style="border-radius: var(--radius-lg);">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 custom-table">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Username</th>
                        <th>Name</th>
                        @if (ViewBag.IsSuperAdmin == true)
                        {
                            <th>Bank</th>
                        }
                        <th>Requested Date</th>
                        <th class="pe-4 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var request in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-medium text-dark">@request.Username</td>
                                <td>@request.Name</td>
                                @if (ViewBag.IsSuperAdmin == true)
                                {
                                    <td><span class="badge bg-light text-dark border">@request.BankName</span></td>
                                }
                                <td>@(((DateTime)request.RequestedDate).ToString("MMM dd, yyyy HH:mm"))</td>
                                <td class="pe-4 text-end">
                                    <form asp-action="ApprovePasswordReset" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to approve this password reset request? This will invalidate their current password immediately.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="username" value="@request.Username" />
                                        <button type="submit" class="btn btn-sm btn-success action-btn">
                                            <i class="bi bi-check-circle me-1"></i> Approve
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="@(ViewBag.IsSuperAdmin == true ? 5 : 4)" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-2 d-block mb-2 text-gray-300"></i>
                                No pending password reset requests.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
