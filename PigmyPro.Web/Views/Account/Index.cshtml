@model PigmyPro.Web.ViewModels.Account.AccountIndexVM

@{
    ViewData["Title"] = "Customer Accounts";
    ViewData["Breadcrumb"] = "<li class='breadcrumb-item active'>Customer Account Opening</li>";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success d-flex align-items-center" role="alert">
        <i class="bi bi-check-circle-fill me-2 fs-5"></i>
        <div>@TempData["Success"]</div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h4 class="page-title">Customer Account Opening</h4>
        <p class="page-subtitle">Complete view of customer accounts</p>
    </div>
    <a href="/Account/Create" class="btn btn-primary">
        <i class="bi bi-person-plus-fill"></i> Open Account
    </a>
</div>

@* ── Filter Panel ── *@
@if (Model.IsSuperAdmin || Model.IsBankAdmin)
{
    <div class="filter-panel">
        <form method="get" action="/Account/Index" class="row g-3 align-items-end">

            @if (Model.IsSuperAdmin)
            {
                <div class="col-md-3">
                    <label class="form-label">Bank Tenant</label>
                    <select name="filterBankID" id="filterBankID" class="form-select" onchange="this.form.requestSubmit()">
                        <option value="">-- Choose Bank --</option>
                        @foreach (var bank in Model.BankList!)
                        {
                            <option value="@bank.Value" selected="@bank.Selected">@bank.Text</option>
                        }
                    </select>
                </div>
            }

            @if (Model.IsBankAdmin || (Model.IsSuperAdmin && Model.FilterBankID.HasValue))
            {
                <div class="col-md-3">
                    <label class="form-label">Branch Office</label>
                    <select name="filterBranchCode" id="filterBranchCode" class="form-select">
                        <option value="">-- All Branches --</option>
                        @if (Model.BranchList != null)
                        {
                            foreach (var br in Model.BranchList)
                            {
                                <option value="@br.Value" selected="@br.Selected">@br.Text</option>
                            }
                        }
                    </select>
                </div>

                @if (Model.IsSuperAdmin)
                {
                    <input type="hidden" name="filterBankID" value="@Model.FilterBankID" />
                }
            }

            @if (!Model.IsSuperAdmin || Model.FilterBankID.HasValue)
            {
                <div class="col-md-3">
                    <label class="form-label">Account Type</label>
                    <select name="filterCode1" id="filterCode1" class="form-select">
                        <option value="">-- All Types --</option>
                        @if (Model.AccountTypeList != null)
                        {
                            foreach (var type in Model.AccountTypeList)
                            {
                                bool isSelected = decimal.TryParse(type.Value, out var val) && val == Model.FilterCode1;
                                <option value="@type.Value" selected="@isSelected">@type.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-filter"></i> Apply
                    </button>
                </div>
            }

            @if (Model.FilterBankID.HasValue || Model.FilterBranchCode.HasValue || Model.FilterCode1.HasValue)
            {
                <div class="col-auto">
                    <a href="/Account/Index" class="btn btn-outline">Clear</a>
                </div>
            }
        </form>
    </div>
}

@* ── Table ── *@
<div class="card">
    <div class="card-body p-0">
        @if (!Model.Accounts.Any())
        {
            <div class="empty-state py-5">
                <i class="bi bi-wallet2 empty-state-icon"></i>
                <div class="empty-state-title">
                    @if (Model.IsSuperAdmin && !Model.FilterBankID.HasValue)
                    {
                        <span>Please select a bank tenant to view customer accounts.</span>
                    }
                    else
                    {
                        <span>No account records found for the current selection.</span>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="d-flex justify-content-end p-3 border-bottom bg-light">
                <div class="input-group" style="max-width: 300px;">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="accountSearch" class="form-control border-start-0" placeholder="Search accounts..." />
                </div>
            </div>
            <div class="table-wrapper">
                <table class="table" id="accountTable">
                    <thead>
                        <tr>
                            <th class="sortable">Type &amp; Account No</th>
                            <th class="sortable">Customer Identity</th>
                            <th class="sortable">Open Date</th>
                            <th class="sortable">Agent</th>
                            <th class="text-end sortable">Current Balance</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var acc in Model.Accounts)
                        {
                            <tr>
                                <td>
                                    @{
                                        var badgeClass = acc.Code1 switch
                                        {
                                            1 => "badge-info",
                                            2 => "badge-warning",
                                            _ => "badge-success"
                                        };
                                    }
                                    <span class="badge @badgeClass" style="margin-right: 8px;">@acc.TypeName</span>
                                    <span class="fw-bold mono-data text-primary">#@acc.Code2.ToString("0")</span>
                                </td>

                                <td>
                                    <div class="fw-bold">@acc.Name</div>
                                    <div class="text-muted" style="font-size: 12px;">
                                        <i class="bi bi-phone"></i> @(acc.MobileNo ?? "N/A")
                                    </div>
                                    @if (!string.IsNullOrEmpty(acc.Address))
                                    {
                                        <div class="text-muted" style="font-size: 12px; margin-top: 2px;">
                                            <i class="bi bi-geo-alt"></i> @acc.Address
                                        </div>
                                    }
                                </td>

                                <td class="text-muted">
                                    @(acc.OpenDate?.ToString("dd-MMM-yyyy") ?? "N/A")
                                </td>

                                <td>
                                    <span class="badge badge-info mono-data" style="font-size: 11px;">AG-@acc.AgnCode?.ToString("0")</span>
                                </td>

                                <td class="text-end">
                                    <div class="fw-bold mono-data text-primary" style="font-size: 15px;">₹@acc.Balance.ToString("N2")</div>
                                </td>

                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/Account/Edit?code1=@acc.Code1&branchCode=@acc.BrncCode&code2=@acc.Code2&bankId=@acc.BankID" class="btn btn-outline btn-sm">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <button type="button" class="btn btn-outline btn-sm text-danger" onclick="confirmDelete(@acc.Code1, @acc.BrncCode, @acc.Code2, @acc.BankID, '@acc.Name')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@* Delete Modal *@
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center p-5">
                <div class="mb-4 text-danger">
                    <i class="bi bi-shield-lock" style="font-size: 64px;"></i>
                </div>
                <h4 class="fw-bold mb-2" style="color: var(--color-text-primary);">Close Account?</h4>
                <p id="deleteMsg" class="text-muted mb-4"></p>

                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="code1" id="deleteCode1" />
                    <input type="hidden" name="branchCode" id="deleteBranchCode" />
                    <input type="hidden" name="code2" id="deleteCode2" />
                    <input type="hidden" name="bankId" id="deleteBankId" />
                    <div class="d-flex gap-3 justify-content-center">
                        <button type="button" class="btn btn-outline" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger px-4">Confirm Removal</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(code1, branchCode, code2, bankId, name) {
            document.getElementById('deleteMsg').textContent = 'Are you sure you want to permanently remove customer account "' + name + '" from the ledger? This action is irreversible.';
            document.getElementById('deleteCode1').value      = code1;
            document.getElementById('deleteBranchCode').value = branchCode;
            document.getElementById('deleteCode2').value      = code2;
            document.getElementById('deleteBankId').value     = bankId;
            document.getElementById('deleteForm').action      = '/Account/Delete';
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }

        document.addEventListener('DOMContentLoaded', () => {
            setupTableSortAndSearch('accountTable', 'accountSearch');
        });
    </script>
}