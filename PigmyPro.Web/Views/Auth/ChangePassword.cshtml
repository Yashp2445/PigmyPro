@model PigmyPro.Web.ViewModels.Auth.ChangePasswordVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Password - PigmyPro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --color-brand-primary:     #3b82f6;
            --color-brand-secondary:   #2563eb;
            --color-bg-base:           #f9fafb;
            --color-bg-surface:        #ffffff;
            --color-border:            #e5e7eb;
            --color-text-primary:      #111827;
            --color-text-secondary:    #4b5563;
            --color-text-muted:        #9ca3af;
            --shadow-lg:   0 12px 28px rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.04);
            --radius-lg:   14px;
            --radius-md:   10px;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background-color: var(--color-bg-base);
            color: var(--color-text-secondary);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px 0;
            -webkit-font-smoothing: antialiased;
        }

        .login-card {
            width: 100%;
            max-width: 480px;
            background: var(--color-bg-surface);
            border-radius: var(--radius-lg);
            box-shadow: 0 0 0 1px rgba(0,0,0,0.05), var(--shadow-lg);
            padding: 40px;
            text-align: center;
        }

        .brand-title {
            font-weight: 700;
            font-size: 24px;
            color: var(--color-text-primary);
            letter-spacing: -0.6px;
            margin-bottom: 8px;
        }

        .brand-subtitle {
            font-size: 13.5px;
            color: var(--color-text-muted);
            margin-bottom: 30px;
        }

        .form-label {
            font-size: 11.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: var(--color-text-muted);
            margin-bottom: 6px;
            display: block;
        }

        .form-control {
            border-radius: var(--radius-md);
            padding: 10px 14px;
            font-size: 14px;
            border: 1px solid var(--color-border);
            background: var(--color-bg-surface);
            color: var(--color-text-primary);
            transition: all 0.15s;
        }

        .form-control:focus {
            border-color: var(--color-brand-primary);
            background: white;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
            outline: none;
        }

        .btn-login {
            background: var(--color-brand-primary);
            color: white;
            border-radius: var(--radius-md);
            padding: 12px;
            font-weight: 600;
            font-size: 14px;
            width: 100%;
            border: none;
            transition: all 0.15s;
            margin-top: 12px;
            box-shadow: 0 1px 3px rgba(59,130,246,0.3);
        }

        .btn-login:hover {
            background: var(--color-brand-secondary);
            color: white;
            box-shadow: 0 6px 16px rgba(59,130,246,0.35);
            transform: translateY(-1px);
        }

        .alert-danger {
            border-radius: var(--radius-md);
            font-size: 13px;
            padding: 12px 16px;
            margin-bottom: 24px;
            background-color: #fef2f2;
            border-color: #fecaca;
            color: #dc2626;
            border-left: 4px solid #dc2626;
            text-align: left;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div style="text-align: center; margin-bottom: 20px; height: 60px;">
            <img src="~/Three%20Star%20Logo.jpg" alt="Three Star Logo" style="max-height: 100%; width: auto; object-fit: contain;" />
        </div>
        <h1 class="brand-title">Change Password</h1>
        <p class="brand-subtitle">Your password has expired or been reset. Please set a new password to continue.</p>

        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div class="mb-1"><i class="bi bi-exclamation-circle me-1"></i> @error.ErrorMessage</div>
                    }
                </div>
            }
            
            <div class="mb-3 text-start">
                <label asp-for="NewPassword" class="form-label">New Password</label>
                <input asp-for="NewPassword" class="form-control" type="password" autofocus required />
                <small class="text-muted" style="font-size: 11px;">Must be at least 4 characters.</small>
            </div>

            <div class="mb-3 text-start">
                <label asp-for="ConfirmNewPassword" class="form-label">Confirm New Password</label>
                <input asp-for="ConfirmNewPassword" class="form-control" type="password" required />
            </div>

            <div class="mb-4 text-start">
                <label asp-for="Reason" class="form-label">Reason for Change</label>
                <input asp-for="Reason" class="form-control" placeholder="e.g. Periodic reset, Forgot password" required />
            </div>

            <button type="submit" class="btn btn-login">Update Password</button>
            <a asp-action="Logout" class="btn btn-link text-muted mt-3" style="font-size: 13px; text-decoration: none;">Cancel and Logout</a>
        </form>
    </div>
</body>
</html>
