@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - PigmyPro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --color-brand-primary:     #3b82f6;
            --color-brand-secondary:   #2563eb;
            --color-bg-base:           #f9fafb;
            --color-bg-surface:        #ffffff;
            --color-border:            #e5e7eb;
            --color-text-primary:      #111827;
            --color-text-secondary:    #4b5563;
            --color-text-muted:        #9ca3af;
            --shadow-lg:   0 12px 28px rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.04);
            --radius-lg:   14px;
            --radius-md:   10px;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background-color: var(--color-bg-base);
            color: var(--color-text-secondary);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            -webkit-font-smoothing: antialiased;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            background: var(--color-bg-surface);
            border-radius: var(--radius-lg);
            box-shadow: 0 0 0 1px rgba(0,0,0,0.05), var(--shadow-lg);
            padding: 48px 40px;
            text-align: center;
        }

        .brand-title {
            font-weight: 700;
            font-size: 24px;
            color: var(--color-text-primary);
            letter-spacing: -0.6px;
            margin-bottom: 8px;
        }

        .brand-subtitle {
            font-size: 13.5px;
            color: var(--color-text-muted);
            margin-bottom: 30px;
        }

        .form-label {
            font-size: 11.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: var(--color-text-muted);
            margin-bottom: 6px;
            display: block;
        }

        .form-control {
            border-radius: var(--radius-md);
            padding: 10px 14px;
            font-size: 14px;
            border: 1px solid var(--color-border);
            background: var(--color-bg-surface);
            color: var(--color-text-primary);
            transition: all 0.15s;
        }

        .form-control:focus {
            border-color: var(--color-brand-primary);
            background: white;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
            outline: none;
        }

        .btn-login {
            background: var(--color-brand-primary);
            color: white;
            border-radius: var(--radius-md);
            padding: 12px;
            font-weight: 600;
            font-size: 14px;
            width: 100%;
            border: none;
            transition: all 0.15s;
            margin-top: 12px;
            box-shadow: 0 1px 3px rgba(59,130,246,0.3);
        }

        .btn-login:hover {
            background: var(--color-brand-secondary);
            color: white;
            box-shadow: 0 6px 16px rgba(59,130,246,0.35);
            transform: translateY(-1px);
        }

        .alert {
            border-radius: var(--radius-md);
            font-size: 13px;
            padding: 12px 16px;
            margin-bottom: 24px;
            border: 1px solid transparent;
            text-align: left;
            display: none; /* hidden by default */
        }
        
        .alert-success {
            background-color: #ecfdf5;
            border-color: #a7f3d0;
            color: #059669;
            border-left: 4px solid #059669;
        }

        .alert-danger {
            background-color: #fef2f2;
            border-color: #fecaca;
            color: #dc2626;
            border-left: 4px solid #dc2626;
        }

        .step-container {
            display: none;
        }

        .step-container.active {
            display: block;
            animation: fadeIn 0.3s;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .otp-timer {
            font-size: 12px;
            color: var(--color-text-muted);
            margin-top: 10px;
        }
        .otp-timer span {
            font-weight: 600;
            color: var(--color-text-primary);
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div style="text-align: center; margin-bottom: 24px; height: 80px;">
            <img src="~/Three%20Star%20Logo.jpg" alt="Three Star Logo" style="max-height: 100%; width: auto; object-fit: contain;" />
        </div>
        <h1 class="brand-title">Forgot Password</h1>

        <div id="alertBox" class="alert"></div>

        <!-- Step 1: Request OTP -->
        <div id="step1" class="step-container active">
            <p class="brand-subtitle">Enter your username to request a reset.</p>
            <form id="formStep1" onsubmit="generateOtp(event)">
                <div class="mb-4 text-start">
                    <label for="username" class="form-label">Username</label>
                    <input type="text" id="username" class="form-control" placeholder="Enter your username" autofocus required />
                </div>
                <button type="submit" id="btnStep1" class="btn btn-login">
                    Request Password Reset
                </button>
            </form>
            <div class="mt-4 text-center">
                <a asp-action="Login" style="font-size: 13px; color: var(--color-brand-primary); text-decoration: none; font-weight: 500;">Back to Login</a>
            </div>
        </div>

        <!-- Step 2: Verify OTP -->
        <div id="step2" class="step-container">
            <p class="brand-subtitle">Enter the 6-digit OTP sent to your registered mobile number.</p>
            <form id="formStep2" onsubmit="verifyOtp(event)">
                <div class="mb-3 text-start">
                    <label for="otp" class="form-label">Enter OTP</label>
                    <input type="text" id="otp" class="form-control text-center fw-bold" placeholder="• • • • • •" maxlength="6" pattern="\d{6}" required autocomplete="off" />
                </div>
                <button type="submit" id="btnStep2" class="btn btn-login">
                    Verify OTP
                </button>
            </form>
            <div class="otp-timer" id="timerDisplay">
                OTP valid for <span id="timeRemaining">15:00</span>
            </div>
            <div class="mt-4 text-center">
                <button type="button" class="btn btn-link p-0 m-0 align-baseline" style="font-size: 13px; color: var(--color-brand-primary); text-decoration: none; font-weight: 500;" onclick="generateOtp(event, true)">Resend OTP</button>
            </div>
        </div>

        <!-- Step 3: Reset Password -->
        <div id="step3" class="step-container">
            <p class="brand-subtitle">Enter your new password.</p>
            <form id="formStep3" onsubmit="resetPassword(event)">
                <div class="mb-3 text-start">
                    <label for="newPassword" class="form-label">New Password</label>
                    <input type="password" id="newPassword" class="form-control" required />
                </div>
                <div class="mb-4 text-start">
                    <label for="confirmPassword" class="form-label">Confirm Password</label>
                    <input type="password" id="confirmPassword" class="form-control" required />
                </div>
                <button type="submit" id="btnStep3" class="btn btn-login">
                    Reset Password
                </button>
            </form>
        </div>

        <!-- Step 4: Success -->
        <div id="step4" class="step-container">
            <div class="mb-4 text-success">
                <i class="bi bi-check-circle" style="font-size: 48px;"></i>
            </div>
            <p class="brand-subtitle fw-bold text-dark">Password successfully changed!</p>
            <p style="font-size: 13px;" class="mb-4">You can now log in using your new password.</p>
            <a asp-action="Login" class="btn btn-login">Return to Login</a>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let resetToken = "";
        let usernameVal = "";
        let timerInterval;
        let expiryTime;

        function showAlert(message, isError = true) {
            const alertBox = document.getElementById('alertBox');
            alertBox.style.display = 'block';
            alertBox.className = 'alert ' + (isError ? 'alert-danger' : 'alert-success');
            alertBox.innerHTML = isError ? `<i class="bi bi-exclamation-circle me-1"></i> ${message}` : `<i class="bi bi-check-circle me-1"></i> ${message}`;
        }

        function hideAlert() {
            document.getElementById('alertBox').style.display = 'none';
        }

        function showStep(stepNum) {
            hideAlert();
            document.querySelectorAll('.step-container').forEach(el => el.classList.remove('active'));
            document.getElementById('step' + stepNum).classList.add('active');
        }

        function startTimer(minutes) {
            clearInterval(timerInterval);
            expiryTime = new Date().getTime() + (minutes * 60 * 1000);
            
            timerInterval = setInterval(function() {
                const now = new Date().getTime();
                const distance = expiryTime - now;
                
                if (distance < 0) {
                    clearInterval(timerInterval);
                    document.getElementById("timeRemaining").innerHTML = "Expired";
                    document.getElementById("timeRemaining").style.color = "#dc2626";
                    return;
                }
                
                const m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const s = Math.floor((distance % (1000 * 60)) / 1000);
                
                document.getElementById("timeRemaining").innerHTML = 
                    (m < 10 ? "0" : "") + m + ":" + (s < 10 ? "0" : "") + s;
                document.getElementById("timeRemaining").style.color = "";
            }, 1000);
        }

        async function generateOtp(e, isResend = false) {
            if (e) e.preventDefault();
            hideAlert();

            const btn = isResend ? null : document.getElementById('btnStep1');
            if (btn) { btn.disabled = true; btn.innerHTML = 'Requesting...'; }

            if (!isResend) {
                usernameVal = document.getElementById('username').value.trim();
            }

            try {
                const formData = new FormData();
                formData.append('username', usernameVal);

                const response = await fetch('/Auth/GenerateResetOtp', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    showAlert(result.message, false);
                    document.getElementById('otp').value = '';
                    showStep(2);
                    startTimer(15); // 15 minutes
                } else {
                    if (result.message.includes("Mobile number not found")) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Registration Required',
                            text: result.message,
                            confirmButtonColor: '#3b82f6'
                        });
                    } else {
                        showAlert(result.message, true);
                    }
                }
            } catch (error) {
                showAlert("An error occurred. Please try again.", true);
            } finally {
                if (btn) { btn.disabled = false; btn.innerHTML = 'Request Password Reset'; }
            }
        }

        async function verifyOtp(e) {
            e.preventDefault();
            hideAlert();

            const btn = document.getElementById('btnStep2');
            const otpVal = document.getElementById('otp').value.trim();
            btn.disabled = true;
            btn.innerHTML = 'Verifying...';

            try {
                const formData = new FormData();
                formData.append('username', usernameVal);
                formData.append('otp', otpVal);

                const response = await fetch('/Auth/VerifyResetOtp', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    resetToken = result.token;
                    showStep(3);
                } else {
                    showAlert(result.message, true);
                }
            } catch (error) {
                showAlert("An error occurred verifying the OTP.", true);
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Verify OTP';
            }
        }

        async function resetPassword(e) {
            e.preventDefault();
            hideAlert();

            const newPass = document.getElementById('newPassword').value;
            const confirmPass = document.getElementById('confirmPassword').value;

            if (newPass !== confirmPass) {
                showAlert("Passwords do not match.", true);
                return;
            }

            const btn = document.getElementById('btnStep3');
            btn.disabled = true;
            btn.innerHTML = 'Resetting...';

            try {
                const formData = new FormData();
                formData.append('username', usernameVal);
                formData.append('newPassword', newPass);
                formData.append('confirmPassword', confirmPass);
                formData.append('token', resetToken);

                const response = await fetch('/Auth/ResetPasswordWithOtp', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    showStep(4);
                } else {
                    showAlert(result.message, true);
                }
            } catch (error) {
                showAlert("An error occurred resetting the password.", true);
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Reset Password';
            }
        }
    </script>
</body>
</html>
