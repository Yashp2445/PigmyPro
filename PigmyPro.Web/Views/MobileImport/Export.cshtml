@model PigmyPro.Web.ViewModels.MobileImport.ExportVM

@{
    ViewData["Title"] = "Export Collections";
    var isBankAdmin = User.IsInRole("BankAdmin");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 style="font-size:18px; font-weight:700; margin:0; color:#0f172a;">Export Collections</h4>
        <p style="font-size:12px; color:#94a3b8; margin:0;">
            Generate a DAT file of pending collections for the selected agent
        </p>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show border-0 mb-4" role="alert"
         style="border-radius:10px; font-size:13px; background:#fef2f2; color:#991b1b; border-left:4px solid #dc2626 !important;">
        <i class="bi bi-exclamation-octagon-fill me-2"></i> @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 mb-4" role="alert"
         style="border-radius:10px; font-size:13px; background:#f0fdf4; color:#166534; border-left:4px solid #16a34a !important;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Filter Panel *@
<div class="card shadow-sm border-0 mb-4" style="border-radius:12px;">
    <div class="card-body p-3">
        <form asp-action="Export" method="post" class="row g-3 align-items-end">

            @if (isBankAdmin)
            {
                <div class="col-md-4">
                    <label class="form-label" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#94a3b8;">
                        Branch
                    </label>
                    <select asp-for="BranchCode" asp-items="Model.Branches"
                            class="form-select form-select-sm" id="ddlBranch"
                            onchange="loadAgents(this.value)">
                        <option value="">-- Select Branch --</option>
                    </select>
                </div>
            }

            <div class="col-md-4">
                <label class="form-label" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#94a3b8;">
                    Agent
                </label>
                <select asp-for="AgentCode" asp-items="Model.Agents"
                        class="form-select form-select-sm" id="ddlAgent"
                        onchange="checkEligibility()">
                    <option value="">-- Select Agent --</option>
                </select>
            </div>

            <div class="col-auto">
                <div class="d-flex gap-2">
                    <button type="submit" id="btnSubmit" class="btn btn-primary btn-sm px-4" disabled>
                        <i class="bi bi-eye me-1"></i> Preview
                    </button>
                    <a href="/Dashboard/Index" class="btn btn-outline-secondary btn-sm px-4">Cancel</a>
                </div>
            </div>

            <div class="col-12 mt-2">
                <div id="eligibilityMessage" style="font-size:12px; min-height: 18px;"></div>
            </div>
        </form>
    </div>
</div>

@if (!Model.HasSearched)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-cloud-arrow-down" style="font-size:42px; opacity:.15;"></i>
        <p class="mt-3" style="font-size:13px;">Select a branch and agent to preview pending collections</p>
    </div>
}
else if (Model.Rows.Any())
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div style="font-size:13px; color:#475569;">
            <strong>@Model.TotalRecords</strong> records &nbsp;|&nbsp;
            Total: <strong class="text-success">₹@Model.TotalAmount.ToString("N2")</strong>
        </div>

        <form asp-action="DownloadExport" method="post">
            <input type="hidden" name="branchCode" value="@Model.BranchCode" />
            <input type="hidden" name="agentCode" value="@Model.AgentCode" />
            <button type="submit" class="btn btn-success btn-sm px-4">
                <i class="bi bi-download me-1"></i> Generate DAT File
            </button>
        </form>
    </div>

    <div class="card shadow-sm border-0" style="border-radius:12px;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:13px;">
                    <thead class="bg-light" style="font-size:11px;text-transform:uppercase;color:#94a3b8;letter-spacing:.5px;">
                        <tr>
                            <th style="padding:11px 18px;">Sr No</th>
                            <th style="padding:11px 18px;">Collection Date</th>
                            <th style="padding:11px 18px;">GL Code</th>
                            <th style="padding:11px 18px;">Account No</th>
                            <th style="padding:11px 18px;">Customer Name</th>
                            <th style="padding:11px 18px; text-align:right;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td style="padding:12px 18px; color:#94a3b8;">@row.SrNo</td>
                                <td style="padding:12px 18px;">@row.CollectionDate.ToString("dd-MMM-yy")</td>
                                <td style="padding:12px 18px;">@row.Code1</td>
                                <td style="padding:12px 18px; font-weight:700; color:#2563eb;">#@row.Code2</td>
                                <td style="padding:12px 18px;">@row.CustomerName</td>
                                <td style="padding:12px 18px; text-align:right; font-weight:700;">₹@row.Amount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="bg-light">
                        <tr>
                            <td colspan="5" style="padding:12px 18px; font-weight:700;">Total</td>
                            <td style="padding:12px 18px; text-align:right; font-weight:700; color:#16a34a;">
                                ₹@Model.TotalAmount.ToString("N2")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function checkEligibility() {
            var branchId = document.getElementById('ddlBranch') ? document.getElementById('ddlBranch').value : '0';
            var agentCode = document.getElementById('ddlAgent').value;
            var btnSubmit = document.getElementById('btnSubmit');
            var msgDiv = document.getElementById('eligibilityMessage');

            if (!btnSubmit || !msgDiv) return;

            // Reset UI
            btnSubmit.disabled = true;
            msgDiv.innerHTML = '';

            if (!agentCode) return;

            msgDiv.innerHTML = '<span class="text-muted"><i class="spinner-border spinner-border-sm me-1" role="status"></i> Checking eligibility...</span>';

            fetch('/MobileImport/CheckExportEligibility?branchCode=' + branchId + '&agentCode=' + agentCode)
                .then(r => r.json())
                .then(data => {
                    if (data.eligible) {
                        msgDiv.innerHTML = '<span class="text-success fw-bold"><i class="bi bi-check-circle-fill me-1"></i> Ready for export</span>';
                        btnSubmit.disabled = false;
                    } else {
                        if (data.readyToCash === true) {
                            msgDiv.innerHTML = '<span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i> Agent is currently marked Ready to Cash &mdash; please complete the upload cycle before exporting again.</span>';
                        } else if (data.hasPendingData === false) {
                            msgDiv.innerHTML = '<span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i> No pending collection data found for this agent &mdash; nothing to export.</span>';
                        } else {
                            msgDiv.innerHTML = '<span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i> Not eligible for export.</span>';
                        }
                    }
                })
                .catch(err => {
                    msgDiv.innerHTML = '<span class="text-danger">Error checking eligibility.</span>';
                });
        }

        function loadAgents(branchId) {
            var $agent = document.getElementById('ddlAgent');
            $agent.innerHTML = '<option value="">-- Loading... --</option>';
            checkEligibility();

            if (!branchId) {
                $agent.innerHTML = '<option value="">-- Select Agent --</option>';
                return;
            }
            fetch('/MobileImport/GetAgents?branchId=' + branchId)
                .then(r => r.json())
                .then(data => {
                    $agent.innerHTML = '<option value="">-- Select Agent --</option>';
                    data.forEach(function(a) {
                        $agent.innerHTML += '<option value="' + a.code + '">' + a.name + '</option>';
                    });
                });
        }
        
        // Trigger check on page load if agent is pre-selected
        document.addEventListener('DOMContentLoaded', function() {
            var agentCode = document.getElementById('ddlAgent') ? document.getElementById('ddlAgent').value : '';
            if (agentCode) {
                checkEligibility();
            }
        });
    </script>
}