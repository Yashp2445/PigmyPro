@model PigmyPro.Web.ViewModels.MobileImport.UploadVM

@{
    ViewData["Title"] = "Upload DAT File";
    var isBankAdmin = User.IsInRole("BankAdmin");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 style="font-size:18px; font-weight:700; margin:0; color:#0f172a;">Upload Collections</h4>
        <p style="font-size:12px; color:#94a3b8; margin:0;">
            Upload a DAT file from the mobile device to import account data
        </p>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show border-0 mb-4" role="alert"
         style="border-radius:10px; font-size:13px; background:#fef2f2; color:#991b1b; border-left:4px solid #dc2626 !important;">
        <i class="bi bi-exclamation-octagon-fill me-2"></i> @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.WarningMessage))
{
    <div class="alert alert-warning alert-dismissible fade show border-0 mb-4" role="alert"
         style="border-radius:10px; font-size:13px; background:#fffbeb; color:#92400e; border-left:4px solid #d97706 !important;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.WarningMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 mb-4" role="alert"
         style="border-radius:10px; font-size:13px; background:#f0fdf4; color:#166534; border-left:4px solid #16a34a !important;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 mb-4" role="alert"
         style="border-radius:10px; font-size:13px; background:#fef2f2; color:#991b1b; border-left:4px solid #dc2626 !important;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.HasParsedData)
{
    @* Step 1 — File Selection *@
    <div class="card shadow-sm border-0" style="border-radius:12px; max-width:520px;">
        <div class="card-header bg-white border-0 py-3">
            <h6 class="mb-0 fw-bold" style="color:#0f172a;">Select DAT File</h6>
            <p class="mb-0" style="font-size:12px; color:#94a3b8;">
                Choose the .DAT file generated by the PigmyPro mobile application
            </p>
        </div>
        <div class="card-body p-4">
            <form asp-action="ParseFile" method="post" enctype="multipart/form-data">

                <div class="row g-3 mb-4">
                    @if (isBankAdmin)
                    {
                        <div class="col-md-6">
                            <label class="form-label" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#94a3b8;">
                                Branch
                            </label>
                            <select asp-for="SelectedBranchCode" asp-items="Model.Branches"
                                    class="form-select form-select-sm" id="ddlBranch"
                                    onchange="loadAgents(this.value)">
                                <option value="">-- Select Branch --</option>
                            </select>
                        </div>
                    }
                    <div class="col-md-6">
                        <label class="form-label" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#94a3b8;">
                            Agent
                        </label>
                        <select asp-for="SelectedAgentCode" asp-items="Model.Agents"
                                class="form-select form-select-sm" id="ddlAgent"
                                onchange="checkEligibility()">
                            <option value="">-- Select Agent --</option>
                        </select>
                    </div>
                    <div class="col-12 mt-2">
                        <div id="eligibilityMessage" style="font-size:12px; min-height: 18px;"></div>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label"
                           style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#94a3b8;">
                        DAT Archive File
                    </label>
                    <input type="file" name="uploadedFile" id="fileInput" class="form-control" accept=".dat,.DAT" required disabled />
                    <div style="font-size:11.5px; color:#94a3b8; margin-top:6px;">
                        <i class="bi bi-info-circle me-1"></i>
                        Only .DAT files exported from PigmyPro mobile are accepted
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" id="btnSubmit" class="btn btn-primary btn-sm px-4" disabled>
                        <i class="bi bi-file-earmark-check me-1"></i> Upload
                    </button>
                    <a href="/Dashboard/Index" class="btn btn-outline-secondary btn-sm px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
}
else
{
    @* Step 2 — Preview and Commit *@
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0" style="border-radius:12px;">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-bold" style="color:#0f172a;">File Contents Preview</h6>
                    <p class="mb-0" style="font-size:12px; color:#94a3b8;">
                        Verify data before committing to the database
                    </p>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="font-size:13px;">
                            <thead class="bg-light"
                                   style="font-size:11px;text-transform:uppercase;color:#94a3b8;letter-spacing:.5px;">
                                <tr>
                                    <th style="padding:11px 18px;">Account No</th>
                                    <th style="padding:11px 18px;">Customer Name</th>
                                    <th style="padding:11px 18px;">Opening Date</th>
                                    <th style="padding:11px 18px; text-align:right;">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.ParsedRows)
                                {
                                    <tr>
                                        <td style="padding:12px 18px; font-weight:700; color:#2563eb;">#@row.Code2</td>
                                        <td style="padding:12px 18px;">@row.Name</td>
                                        <td style="padding:12px 18px; color:#94a3b8;">@row.OpnDate.ToString("dd-MMM-yy")</td>
                                        <td style="padding:12px 18px; text-align:right; font-weight:700;">₹@row.Amount.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0" style="border-radius:12px; background:#f8fafc;">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-4" style="color:#0f172a;">Import Summary</h6>

                    <div class="mb-3">
                        <div style="font-size:11px; color:#94a3b8; font-weight:700; text-transform:uppercase; letter-spacing:.4px;">
                            Agent / Branch
                        </div>
                        <div style="font-size:15px; font-weight:700; color:#0f172a;">
                            @Model.AgentCode &nbsp;/&nbsp; @Model.BranchCode
                        </div>
                        @if (!string.IsNullOrEmpty(Model.AgentName))
                        {
                            <div style="font-size:12px; color:#475569;">@Model.AgentName</div>
                        }
                    </div>

                    <div class="mb-4">
                        <div style="font-size:11px; color:#94a3b8; font-weight:700; text-transform:uppercase; letter-spacing:.4px;">
                            File Date
                        </div>
                        <div style="font-size:15px; font-weight:700; color:#0f172a;">
                            @Model.Date.ToString("dd-MMM-yyyy")
                        </div>
                    </div>

                    <hr style="border-color:#e2e8f0;" />

                    <div class="mb-3 p-3 bg-white rounded" style="border:1px solid #e2e8f0;">
                        <div style="font-size:11px; color:#94a3b8;">Total Records</div>
                        <div style="font-size:22px; font-weight:700; color:#2563eb;">@Model.TotalRecords</div>
                    </div>

                    <div class="mb-4 p-3 bg-white rounded" style="border:1px solid #e2e8f0;">
                        <div style="font-size:11px; color:#94a3b8;">Total Balance</div>
                        <div style="font-size:22px; font-weight:700; color:#16a34a;">₹@Model.TotalAmount.ToString("N2")</div>
                    </div>

                    <form asp-action="CommitUpload" method="post">
                        <input type="hidden" asp-for="BranchCode" />
                        <input type="hidden" asp-for="AgentCode" />
                        <input type="hidden" asp-for="Date" />
                        <input type="hidden" asp-for="TotalRecords" />
                        <input type="hidden" asp-for="TotalAmount" />
                        <input type="hidden" asp-for="ParsedRowsJson" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-cloud-upload me-1"></i> Upload Data
                            </button>
                            <a href="/MobileImport/Upload" class="btn btn-outline-secondary btn-sm">
                                Cancel &amp; Start Over
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function checkEligibility() {
            var branchId = document.getElementById('ddlBranch') ? document.getElementById('ddlBranch').value : '0';
            var agentCode = document.getElementById('ddlAgent').value;
            var fileInput = document.getElementById('fileInput');
            var btnSubmit = document.getElementById('btnSubmit');
            var msgDiv = document.getElementById('eligibilityMessage');

            if (!fileInput || !btnSubmit || !msgDiv) return;

            // Reset UI
            fileInput.disabled = true;
            fileInput.value = '';
            btnSubmit.disabled = true;
            msgDiv.innerHTML = '';

            if (!agentCode) return;

            msgDiv.innerHTML = '<span class="text-muted"><i class="spinner-border spinner-border-sm me-1" role="status"></i> Checking eligibility...</span>';

            fetch('/MobileImport/CheckUploadEligibility?branchCode=' + branchId + '&agentCode=' + agentCode)
                .then(r => r.json())
                .then(data => {
                    if (data.eligible) {
                        msgDiv.innerHTML = '<span class="text-success fw-bold"><i class="bi bi-check-circle-fill me-1"></i> Ready for upload</span>';
                        fileInput.disabled = false;
                        btnSubmit.disabled = false;
                    } else {
                        if (data.readyToCash === false) {
                            msgDiv.innerHTML = '<span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i> Agent is not marked Ready to Cash on mobile.</span>';
                        } else if (data.hasPendingData === true) {
                            msgDiv.innerHTML = '<span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i> Agent already has pending collection data in the system &mdash; please export and clear existing data before uploading a new master file.</span>';
                        } else {
                            msgDiv.innerHTML = '<span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i> Not eligible for upload.</span>';
                        }
                    }
                })
                .catch(err => {
                    msgDiv.innerHTML = '<span class="text-danger">Error checking eligibility.</span>';
                });
        }

        function loadAgents(branchId) {
            var $agent = document.getElementById('ddlAgent');
            $agent.innerHTML = '<option value="">-- Loading... --</option>';
            checkEligibility();

            if (!branchId) {
                $agent.innerHTML = '<option value="">-- Select Agent --</option>';
                return;
            }
            fetch('/MobileImport/GetAgents?branchId=' + branchId)
                .then(r => r.json())
                .then(data => {
                    $agent.innerHTML = '<option value="">-- Select Agent --</option>';
                    data.forEach(function(a) {
                        $agent.innerHTML += '<option value="' + a.code + '">' + a.name + '</option>';
                    });
                });
        }
        
        // Trigger check on page load if agent is pre-selected
        document.addEventListener('DOMContentLoaded', function() {
            var agentCode = document.getElementById('ddlAgent') ? document.getElementById('ddlAgent').value : '';
            if (agentCode) {
                checkEligibility();
            }
        });
    </script>
}