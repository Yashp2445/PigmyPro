@model IEnumerable<PigmyPro.Web.ViewModels.Branch.BranchListVM>

@{
    ViewData["Title"] = "Branches";
    ViewData["Breadcrumb"] = "<li class='breadcrumb-item active'>Branch Directory</li>";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success d-flex align-items-center" role="alert">
        <i class="bi bi-check-circle-fill me-2 fs-5"></i>
        <div>@TempData["Success"]</div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-octagon-fill me-2 fs-5"></i>
        <div>@TempData["Error"]</div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

@using PigmyPro.Web.ViewModels.Shared

@{
    var headerSubtitle = ViewBag.BankName != null ? "Operating branches for " + ViewBag.BankName : "Comprehensive list of all branch offices";
    var header = new PageHeaderVM {
        Title = "Branch Directory",
        Subtitle = headerSubtitle,
        ActionsHtml = @"<a href=""/Branch/Create"" class=""btn btn-primary""><i class=""bi bi-plus-lg""></i> New Branch</a>"
    };
}
<partial name="_PageHeader" model="header" />

@if (ViewBag.IsSuperAdmin == true)
{
    <div class="filter-panel">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Select Bank Tenant</label>
                <select name="bankId" class="form-select">
                    <option value="">-- All Banks --</option>
                    @foreach (var bank in ViewBag.BankList)
                    {
                        <option value="@bank.Value" selected="@(bank.Value == ViewBag.SelectedBankID?.ToString())">@bank.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-funnel"></i> Filter
                </button>
            </div>
        </form>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state py-5">
                <i class="bi bi-geo-alt empty-state-icon"></i>
                <div class="empty-state-title">
                    @if (ViewBag.IsSuperAdmin == true && (int)ViewBag.SelectedBankID == 0)
                    {
                        <span>Please select a bank to view its branches.</span>
                    }
                    else
                    {
                        <span>No branches found for the current selection.</span>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="table-wrapper">
                <div class="table-responsive">
                    <table class="table">
                    <thead>
                        <tr>
                            <th>Branch Name</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">
                                    <div class="cell-truncate" title="@item.Name">@item.Name</div>
                                </td>
                                <td>
                                    @if (item.IsActive == "Active")
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/Branch/Edit/@item.BranchID?bankId=@item.BankID" class="btn btn-outline btn-sm">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        @if(item.CanDelete)
                                        {
                                            <button type="button" class="btn btn-outline btn-sm text-danger" onclick="confirmDelete(@item.BranchID, @item.BankID, '@item.Name')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-outline btn-sm text-muted" style="cursor: not-allowed; opacity: 0.65;" onclick="showDependencyError('@item.DependencyMessage')" title="Cannot delete: @item.DependencyMessage">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            </div>
        }
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function showDependencyError(message) {
            Swal.fire({
                icon: 'warning',
                title: 'Cannot Delete',
                text: message,
                confirmButtonColor: '#2563eb'
            });
        }

        function confirmDelete(id, bankId, name) {
            Swal.fire({
                title: 'Remove Branch?',
                text: 'Are you sure you want to permanently remove branch "' + name + '"?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Delete Branch'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.createElement('form');
                    form.method = 'post';
                    form.action = '/Branch/Delete';
                    
                    const token = document.createElement('input');
                    token.type = 'hidden';
                    token.name = '__RequestVerificationToken';
                    token.value = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    form.appendChild(token);

                    const idInput = document.createElement('input');
                    idInput.type = 'hidden';
                    idInput.name = 'id';
                    idInput.value = id;
                    form.appendChild(idInput);

                    const bankIdInput = document.createElement('input');
                    bankIdInput.type = 'hidden';
                    bankIdInput.name = 'bankId';
                    bankIdInput.value = bankId;
                    form.appendChild(bankIdInput);

                    document.body.appendChild(form);
                    form.submit();
                }
            });
        }
    </script>
}